# =============================================================================
# Erable .gitignore
# Monorepo: Python (backend) + Node/Next.js (frontend) + Docker + IDE + secrets
# =============================================================================

# -----------------------------------------------------------------------------
# Secrets and environment files
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
*.crt
*.p12
*.keystore
secrets/
.secrets/

# -----------------------------------------------------------------------------
# Python (backend)
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# uv / pip
.venv/
venv/
env/
ENV/
.python-version
pip-log.txt
pip-delete-this-directory.txt

# Pytest / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
*.py,cover
.hypothesis/
nosetests.xml

# mypy / ruff / type checking
.mypy_cache/
.ruff_cache/
.pyre/
.pytype/
.dmypy.json
dmypy.json

# Jupyter / IPython
.ipynb_checkpoints
profile_default/
ipython_config.py

# Alembic local artifacts (migrations themselves are tracked)
backend/alembic/versions/__pycache__/

# -----------------------------------------------------------------------------
# Node / Next.js (frontend)
# -----------------------------------------------------------------------------
node_modules/
.pnpm-store/
.yarn/
.npm/
.next/
out/
build/
.turbo/
.swc/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Optional: lockfiles from other package managers (we use pnpm)
package-lock.json
yarn.lock

# TypeScript
*.tsbuildinfo
next-env.d.ts

# Testing
coverage/
.nyc_output/
playwright-report/
playwright/.cache/
test-results/

# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
.docker/
docker-compose.override.yml
docker-compose.override.yaml

# -----------------------------------------------------------------------------
# Terraform (infrastructure/aws/)
# -----------------------------------------------------------------------------
.terraform/
.terraform.lock.hcl
*.tfstate
*.tfstate.*
*.tfvars
!*.tfvars.example
crash.log
crash.*.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# -----------------------------------------------------------------------------
# IDE / Editors
# -----------------------------------------------------------------------------

# JetBrains (WebStorm, PyCharm)
.idea/
*.iml
*.ipr
*.iws
out/

# VS Code
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/tasks.json
.history/

# Vim / Emacs
*.swp
*.swo
*~
.netrwhist
\#*\#
.\#*

# Sublime / Atom
*.sublime-project
*.sublime-workspace
.atom/

# -----------------------------------------------------------------------------
# OS-specific
# -----------------------------------------------------------------------------

# Linux (Fedora KDE)
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*

# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# -----------------------------------------------------------------------------
# Logs and temporary files
# -----------------------------------------------------------------------------
*.log
logs/
tmp/
temp/
.cache/

# -----------------------------------------------------------------------------
# Backup files
# -----------------------------------------------------------------------------
*.bak
*.backup
*.old
*.orig

# -----------------------------------------------------------------------------
# Local data (Postgres dumps, Redis snapshots, sample uploads)
# -----------------------------------------------------------------------------
*.dump
*.sql.gz
dump.rdb
appendonly.aof
local-data/
.local/

# -----------------------------------------------------------------------------
# Documentation build outputs
# -----------------------------------------------------------------------------
docs/_build/
docs/.docusaurus/
site/
