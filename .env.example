# =============================================================================
# Erable — Environment variables template
# Copy this file to .env and fill in actual values for local development.
# Never commit the .env file.
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_ENV=development
APP_NAME=erable
APP_URL=http://localhost:3000
API_URL=http://localhost:8000
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Database (PostgreSQL 16 + pgvector)
# -----------------------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=erable
POSTGRES_USER=erable
POSTGRES_PASSWORD=
DATABASE_URL=postgresql+asyncpg://erable:@postgres:5432/erable

# -----------------------------------------------------------------------------
# Redis (cache, rate limiting, ARQ broker)
# -----------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://redis:6379/0
REDIS_ARQ_DB=1

# -----------------------------------------------------------------------------
# Authentication (JWT custom)
# -----------------------------------------------------------------------------
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30
PASSWORD_HASH_ALGO=argon2id

# -----------------------------------------------------------------------------
# LLM providers
# -----------------------------------------------------------------------------
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=mistral:7b-instruct-q4_K_M

# -----------------------------------------------------------------------------
# Embeddings (BGE-M3 multilingue)
# -----------------------------------------------------------------------------
EMBEDDINGS_PROVIDER=local
EMBEDDINGS_MODEL=BAAI/bge-m3
EMBEDDINGS_DIMENSION=1024

# -----------------------------------------------------------------------------
# OCR (Tesseract local + Claude Vision fallback)
# -----------------------------------------------------------------------------
OCR_ENGINE=tesseract
TESSERACT_PATH=/usr/bin/tesseract
TESSERACT_LANGUAGES=fra+eng

# -----------------------------------------------------------------------------
# Payments (Lemon Squeezy)
# -----------------------------------------------------------------------------
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Email (Resend)
# -----------------------------------------------------------------------------
RESEND_API_KEY=
EMAIL_FROM=bonjour@erable.app
EMAIL_FROM_NAME=Erable

# -----------------------------------------------------------------------------
# Observability
# -----------------------------------------------------------------------------
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=erable-backend

# -----------------------------------------------------------------------------
# Affiliate tracking
# -----------------------------------------------------------------------------
AFFILIATE_FINGERPRINT_SALT=
AFFILIATE_CLICK_RETENTION_DAYS=180

# -----------------------------------------------------------------------------
# Freshness pipeline (RAG re-crawl)
# -----------------------------------------------------------------------------
CRAWLER_USER_AGENT=ErableBot/1.0 (+https://erable.app/bot)
CRAWLER_REQUEST_DELAY_SECONDS=2
CRAWLER_TIMEOUT_SECONDS=30
FRESHNESS_RECRAWL_CRON=0 3 * * 0

# -----------------------------------------------------------------------------
# Frontend (Next.js public env vars must be prefixed with NEXT_PUBLIC_)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_DEFAULT_LOCALE=fr
NEXT_PUBLIC_SENTRY_DSN=

# -----------------------------------------------------------------------------
# CORS / Security
# -----------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:3000
RATE_LIMIT_PER_MINUTE=60
